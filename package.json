{
  "name": "fidelbridge",
  "version": "0.1.0",
  "private": true,
  "description": "FidelBridge frontend build tooling (Tailwind CSS)",
  "scripts": {
    "postinstall": "node scripts/copy-vendor.js",
    "build": "tailwindcss -i ./app/static/src/input.css -o ./app/static/css/output.css --minify",
    "watch": "tailwindcss -i ./app/static/src/input.css -o ./app/static/css/output.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.4"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "alpinejs": "^3.15.12"
  }
}
