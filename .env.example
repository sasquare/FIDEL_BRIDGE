# Copy this file to .env and fill in real values. Never commit .env.
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
DATABASE_URL=sqlite:///instance/fidelbridge.db

# Optional: outbound email for password reset. Leave unset in development -
# reset links are logged to the console instead of emailed (see app/utils/mail.py).
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-smtp-username
# MAIL_PASSWORD=your-smtp-password
# MAIL_DEFAULT_SENDER=no-reply@fidelbridge.com
